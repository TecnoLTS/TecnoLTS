# Runtime
APP_ENV=production
HOST_PORT=3008
DEV_PORT=3009

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://tecnolts.com

# Contact Information
NEXT_PUBLIC_CONTACT_EMAIL=info@tecnolts.com
NEXT_PUBLIC_CONTACT_PHONE=+57 300 000 0000

# Gmail Configuration for Contact Form
# IMPORTANTE: Configura estos valores antes de usar el formulario
# 1. Usa tu cuenta de Gmail en GMAIL_USER
# 2. Crea una contraseña de aplicación en: https://myaccount.google.com/apppasswords
# 3. Pega la contraseña de 16 caracteres en GMAIL_APP_PASSWORD
GMAIL_USER=tu-correo@gmail.com
GMAIL_APP_PASSWORD=tu_app_password_de_16_caracteres
EMAIL_TO=destino@tu-dominio.com

# Optional: Analytics
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
