# Runtime
APP_ENV=production
COMPOSE_PROFILES=production
HOST_PORT=3008
DEV_PORT=3009
BUILD_MAX_OLD_SPACE_SIZE=1024
FRONTEND_DEV_RUNTIME=stable
FRONTEND_DEV_BUNDLER=webpack
# Optional (dev): comma-separated hostnames allowed to access `/_next/*` in `next dev`
# Accepts hostnames or URLs; hostnames are recommended.
# Example (LAN): 192.168.100.229,localhost
NEXT_ALLOWED_DEV_ORIGINS=localhost,127.0.0.1,192.168.100.229

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://tecnolts.com
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_YANDEX_VERIFICATION=
NEXT_PUBLIC_YAHOO_VERIFICATION=

# Contact Information
NEXT_PUBLIC_CONTACT_EMAIL=info@tecnolts.com
NEXT_PUBLIC_CONTACT_PHONE=+593 96 368 2212
NEXT_PUBLIC_CONTACT_LOCALITY=Quito
NEXT_PUBLIC_CONTACT_REGION=Pichincha
NEXT_PUBLIC_CONTACT_COUNTRY_CODE=EC
NEXT_PUBLIC_CONTACT_COUNTRY_NAME=Ecuador
NEXT_PUBLIC_CONTACT_STREET_ADDRESS=
NEXT_PUBLIC_CONTACT_POSTAL_CODE=
NEXT_PUBLIC_CONTACT_LATITUDE=
NEXT_PUBLIC_CONTACT_LONGITUDE=
NEXT_PUBLIC_GOOGLE_MAPS_URL=
NEXT_PUBLIC_GOOGLE_BUSINESS_PROFILE_URL=

# Optional: Brand Profiles (recommended for SEO entity consistency)
NEXT_PUBLIC_LINKEDIN_URL=
NEXT_PUBLIC_FACEBOOK_URL=
NEXT_PUBLIC_INSTAGRAM_URL=
NEXT_PUBLIC_X_URL=
NEXT_PUBLIC_TIKTOK_URL=
NEXT_PUBLIC_YOUTUBE_URL=

# SMTP Configuration for Contact Form
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_TLS_SERVERNAME=
SMTP_TLS_INSECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Compatibilidad legado (Gmail)
GMAIL_USER=tu-correo@gmail.com
GMAIL_APP_PASSWORD=tu_app_password_de_16_caracteres
EMAIL_TO=destino@tu-dominio.com

# Optional: Analytics
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Optional: Distributed rate limiting (recommended in multi-instance production)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
